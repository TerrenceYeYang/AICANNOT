# --- Database (Postgres) ----------------------------------------------------
# Pooled connection (PgBouncer) — used by the app at runtime. On Neon this is
# the host containing "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/DB?sslmode=require"
# Direct (unpooled) connection — used by Prisma migrations only.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.neon.tech/DB?sslmode=require"

# --- Security ---------------------------------------------------------------
# Signs anti-bot form timing tokens. Generate with: openssl rand -hex 32
# Falls back to an insecure dev value if unset — MUST be set in production.
FORM_SECRET=

# --- Pay-to-unlock (EVM, read-only — the app never holds a private key or
# sends a transaction; it only verifies that a payment arrived) ------------
# Chain to verify payments on. Use Base Sepolia (84532) for testing,
# Base mainnet (8453) for real funds. Always change RPC_URL together with this.
CHAIN_ID=84532
RPC_URL="https://sepolia.base.org"
# The site's single receiving address. Funds sent here are verified by
# reading public chain data — the app does not custody or move them.
RECEIVING_ADDRESS="0xYourReceivingAddressHere"
# Confirmations required (block depth past the tx's block) before a payment
# is accepted as final.
MIN_CONFIRMATIONS=2
# Signs the "privately unlocked answers" cookie. Generate with: openssl rand -hex 32
# Falls back to an insecure dev value if unset — MUST be set in production.
UNLOCK_SECRET=
